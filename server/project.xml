<?xml version="1.0" encoding="utf-8"?>
<project>
    <meta title="Stack Platform Integration Server" package="com.example.stackplatform.server" version="1.0.0" company="Example" />
    <app main="Main" path="Export" file="StackServer" />
    
    <source path="Source" />
    <source path="../shared" />
    
    <haxelib name="lime" />
    <haxelib name="SideWinder" />
    <haxelib name="snake-server" />
    <haxelib name="haxe-injection" />
    <haxelib name="hxwell" />
    <haxelib name="json2object" />
    <haxelib name="utest" />
    <haxelib name="uuid" />
    <haxelib name="stack-platform-sdk" />
    
    <haxedef name="disable_env" />
    
    <assets path="static" />
    
    <postbuild command="copy-server-hdlls.bat" if="hl" />
    <postbuild command="copy-server-hdlls.bat" if="hlc" />
</project>
