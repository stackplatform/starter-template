{
  "projectId": "example-project",
  "version": "auto",
  "description": "Starter template release",
  "builds": [
    {
      "name": "server-linux-x64",
      "platform": "linux",
      "arch": "x64",
      "command": "haxe -cp scripts --run BuildMock linux",
      "artifact": "dist/server-linux-x64.zip"
    },
    {
      "name": "server-windows-x64",
      "platform": "windows",
      "arch": "x64",
      "command": "haxe -cp scripts --run BuildMock windows",
      "artifact": "dist/server-windows-x64.zip"
    }
  ]
}
