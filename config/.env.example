# Stack Platform Starter Template Configuration
# Copy this file to .env and fill in the values.
# NEVER commit your real .env file to version control.

# 1. The API Key (spk_proj_...) for your Stack Platform project.
# Create this in the Project Settings -> API Keys section of the dashboard.
STACK_PROJECT_API_KEY=your_project_api_key_here

# 2. Environment name (e.g. development, staging, production)
STACK_PROJECT_ENV=development

# 3. Optional: Stack Platform API URL if using a custom/local instance
# Default is 'https://api.stackplatform.com' if not SET.
STACK_PLATFORM_URL=https://api.stackplatform.com

# 4. Local server port
PORT=8081
